# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── File Watching ──────────────────────────────────────────────────────────────
WATCH_FOLDER=./data/watch

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/summaries.db

# ── Server ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Logging ────────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
